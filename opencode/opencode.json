{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "deepseek-v4-pro",
  "small_model": "deepseek-v4-flash",
  "agent": {
    "build": {
      "color": "#ff8c42"
    },
    "plan": {
      "color": "#5b9eff"
    }
  },
  "provider": {
    "bailian-token-plan": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Alibaba Cloud Model Studio",
      "options": {
        "baseURL": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "sk-xxxxxx"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        },
        "deepseek-v4-flash": {
            "name": "DeepSeek V4 Flash",
            "options": {}
        },
        "glm-5": {
          "name": "GLM-5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 8192
            }
          }
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**",
      "__pycache__/**",
      "*.pyc"
    ]
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "doom_loop": "allow",
    "external_directory": "allow"
  },
  "share": "manual",
  "lsp": {
    "dart": {
      "command": ["dart", "language-server"],
      "extensions": [".dart"]
    }
  },
  "plugin": [],
  "instructions": [
    "~/.claude/CLAUDE.md",
    "~/.claude/rules/*.md"
  ]
}
